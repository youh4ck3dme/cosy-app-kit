# Copy to .env locally. Do NOT commit real values (GitGuardian).
# On Lovable Cloud: set these in Project → Cloud → Secrets (and reconnect Supabase).

SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server-only secret — Lovable Secrets / local .env only
MISTRAL_API_KEY=

# Optional: HMAC for private multi-file iframe preview tokens.
# Falls back to MISTRAL_API_KEY / SUPABASE_PUBLISHABLE_KEY if unset.
# PREVIEW_SIGNING_SECRET=
